<!--detail.wxml-->
<view class="container">
  <view class="header">
    <text class="name">{{surname}}{{name}}</text>
    <view class="score-badge">
      <text class="score">{{score}}</text>
      <text class="label">分</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">📝 寓意</view>
    <view class="section-content">{{meaning}}</view>
  </view>

  <view class="section">
    <view class="section-title">📖 出处</view>
    <view class="section-content">{{source}}</view>
  </view>

  <view class="section">
    <view class="section-title">🔢 五行分析</view>
    <view class="wuxing-grid">
      <view class="wuxing-item">
        <text class="wuxing-label">五行</text>
        <text class="wuxing-value">{{wuxing}}</text>
      </view>
      <view class="wuxing-item">
        <text class="wuxing-label">笔画</text>
        <text class="wuxing-value">{{strokes}}</text>
      </view>
      <view class="wuxing-item">
        <text class="wuxing-label">音调</text>
        <text class="wuxing-value">{{tone}}</text>
      </view>
      <view class="wuxing-item">
        <text class="wuxing-label">结构</text>
        <text class="wuxing-value">{{structure}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">📊 综合评分</view>
    <view class="score-details">
      <view class="score-item">
        <text class="score-item-label">音韵</text>
        <view class="score-bar">
          <view class="score-bar-fill" style="width: {{scores.sound}}%"></view>
        </view>
        <text class="score-item-value">{{scores.sound}}分</text>
      </view>
      <view class="score-item">
        <text class="score-item-label">字形</text>
        <view class="score-bar">
          <view class="score-bar-fill" style="width: {{scores.shape}}%"></view>
        </view>
        <text class="score-item-value">{{scores.shape}}分</text>
      </view>
      <view class="score-item">
        <text class="score-item-label">寓意</text>
        <view class="score-bar">
          <view class="score-bar-fill" style="width: {{scores.meaning}}%"></view>
        </view>
        <text class="score-item-value">{{scores.meaning}}分</text>
      </view>
      <view class="score-item">
        <text class="score-item-label">五行</text>
        <view class="score-bar">
          <view class="score-bar-fill" style="width: {{scores.wuxing}}%"></view>
        </view>
        <text class="score-item-value">{{scores.wuxing}}分</text>
      </view>
    </view>
  </view>

  <view class="actions">
    <button class="action-btn collect" bindtap="collect">
      <text>❤️ 收藏</text>
    </button>
    <button class="action-btn share" open-type="share">
      <text>📤 分享</text>
    </button>
  </view>
</view>
