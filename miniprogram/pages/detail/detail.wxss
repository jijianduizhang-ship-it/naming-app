/* detail.wxss */
page {
  background: #F5F5F5;
  min-height: 100vh;
}

.container {
  padding: 30rpx;
}

.header {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.name {
  font-size: 64rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 20rpx;
}

.score-badge {
  display: inline-flex;
  align-items: baseline;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
}

.score {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-left: 4rpx;
}

.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.wuxing-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.wuxing-item {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.wuxing-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.wuxing-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

.score-details {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.score-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-item-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
}

.score-bar {
  flex: 1;
  height: 16rpx;
  background: #E8F5E9;
  border-radius: 8rpx;
  overflow: hidden;
}

.score-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #2E7D32);
  border-radius: 8rpx;
}

.score-item-value {
  width: 80rpx;
  font-size: 24rpx;
  color: #4CAF50;
  text-align: right;
}

.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.collect {
  background: white;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
}

.action-btn.share {
  background: #4CAF50;
  color: white;
}
