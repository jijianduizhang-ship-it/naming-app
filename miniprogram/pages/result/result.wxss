/* result.wxss */
page {
  background: #F5F5F5;
  min-height: 100vh;
}

.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.names-list {
  height: calc(100vh - 300rpx);
}

.name-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.name-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.name {
  font-size: 48rpx;
  font-weight: bold;
  color: #2E7D32;
}

.score-badge {
  display: flex;
  align-items: baseline;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

.score {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-left: 4rpx;
}

.name-info {
  margin-bottom: 20rpx;
}

.meaning, .source {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 70rpx;
  background: #F5F5F5;
  border-radius: 35rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx 40rpx;
  background: white;
}

.refresh-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 48rpx;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}
